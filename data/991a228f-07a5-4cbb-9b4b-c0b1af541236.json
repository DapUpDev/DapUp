":"tag","type":"string","defaultValue":""}],"actions":{"be75c146-1661-4d3e-99d3-a624a7a86b58":{"id":"be75c146-1661-4d3e-99d3-a624a7a86b58","code":"// Get current selected tags\n  const currentTags = [...variables['950c4714-ba2c-4b63-975d-887a48496abe']];\n  \n  // Check if tag already exists in the array\n  const tagIndex = currentTags.findIndex(t => t === context.parameters['tag']);\n  \n  if (tagIndex >= 0) {\n    // Tag exists, remove it\n    currentTags.splice(tagIndex, 1);\n  } else {\n    // Tag doesn't exist, add it\n    currentTags.push(context.parameters['tag']);\n  }\n  \n  // Update the selectedTags variable\n  variables['950c4714-ba2c-4b63-975d-887a48496abe'] = currentTags;","next":null,"type":"custom-js"}},"firstAction":"be75c146-1661-4d3e-99d3-a624a7a86b58","firstErrorAction":null}],"formulas":[{"id":"a8e950b3-7290-4ef0-aca7-04df1947a1b5","code":"// Get the mentors array and selected filters\n  const mentors = variables[\"0bb5b191-0f20-4827-8829-3528db948965\"] || [];\n  const selectedSubjects = variables['950c4714-ba2c-4b63-975d-887a48496abe'] || [];\n  const selectedRegions = variables['76817604-c539-46bb-b766-dec5537ce44d'] || [];\n  \n  // Start with all mentors\n  let filteredMentors = [...mentors];\n  \n  // Filter by subjects if any are selected\n  if (selectedSubjects.length > 0) {\n    filteredMentors = filteredMentors.filter(mentor => {\n      // Check if mentor's subject is in the selected subjects\n      return selectedSubjects.includes(mentor.subject);\n    });\n  }\n  \n  // Filter by regions if any are selected\n  if (selectedRegions.length > 0) {\n    filteredMentors = filteredMentors.filter(mentor => {\n      // Check if mentor's region is in the selected regions\n      return selectedRegions.includes(mentor.region);\n    });\n  }\n  \n  return filteredMentors;","parameters":[],"isAsync":false,"type":"js","filter":[],"sort":[]}],"libraryComponents":[{"id":"c47f9b0f-723d-46f7-962a-789ff0d1e75d","configuration":{"editor":{"customStylePro