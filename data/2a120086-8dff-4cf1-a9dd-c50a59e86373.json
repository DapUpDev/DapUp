rd must be at least 8 characters long\";\n    return { isValid: false };\n  }\n  \n  // Check for at least one uppercase letter\n  if (!/[A-Z]/.test(newPassword)) {\n    variables['aad5e890-cb44-4993-89e8-b2927223c823'] = \"Password must contain at least 1 uppercase letter\";\n    return { isValid: false };\n  }\n  \n  // Check if new password is same as old password\n  // In a real application, you would compare with the actual old password\n  // For this example, we'll use a hardcoded value \"OldPassword123\" to simulate the check\n  if (newPassword === \"OldPassword123\") {\n    variables['aad5e890-cb44-4993-89e8-b2927223c823'] = \"New password cannot be the same as your old password\";\n    return { isValid: false };\n  }\n  \n  // Clear any previous error\n  variables['aad5e890-cb44-4993-89e8-b2927223c823'] = \"\";\n  \n  return { \n    isValid: true,\n    password: newPassword\n  };","next":null,"type":"custom-js"}},"firstAction":"20539a4b-da87-4106-b8a6-9482d8eb6c06","firstErrorAction":null},{"id":"08126d7c-c940-4195-85f3-8a4eb8b22efb","parameters":[],"actions":{"75ca5ce2-5a50-4480-81eb-a0e0b519c92b":{"id":"75ca5ce2-5a50-4480-81eb-a0e0b519c92b","code":"// Only clear errors if we've attempted to submit the form\n  if (variables['e8425a71-427d-4472-a536-abca8649e9b8']) {\n    // Clear the auth error\n    variables['aad5e890-cb44-4993-89e8-b2927223c823'] = \"\";\n  }","next":null,"type":"custom-js"}},"firstAction":"75ca5ce2-5a50-4480-81eb-a0e0b519c92b","firstErrorAction":null}],"formulas":[],"libraryComponents":[]}